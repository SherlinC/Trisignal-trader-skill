{
  "version": "v4.3-lite",
  "mode": "paper",
  "timeframe": "4h",
  "symbols": [
    "BTC-USDT-SWAP",
    "ETH-USDT-SWAP",
    "SOL-USDT-SWAP",
    "XRP-USDT-SWAP"
  ],
  "hard_constraints": {
    "risk_per_trade": 0.03,
    "daily_drawdown_limit": 0.08,
    "max_open_positions": 2,
    "allow_hedge": false,
    "required_order_tag": "agentTradeKit",
    "order_type": "market",
    "stop_loss_pct_long": 0.02,
    "stop_loss_pct_short": 0.02
  },
  "score_rules": {
    "strong_entry_score": 55,
    "conservative_entry_score": 42,
    "watch_score": 38,
    "min_gap_strong": 4,
    "min_gap_conservative": 1
  },
  "position_rules": {
    "strong_entry_risk_multiplier": 1.0,
    "conservative_entry_risk_multiplier": 0.5,
    "min_order_size": 0.001,
    "max_order_size": 1000000
  },
  "penalty_rules": {
    "funding_crowded_threshold": 0.001,
    "funding_extreme_threshold": 0.003,
    "atr_low_threshold": 0.006,
    "atr_high_threshold": 0.05,
    "atr_extreme_low_threshold": 0.003,
    "atr_extreme_high_threshold": 0.08,
    "event_conflict_penalty_enabled": true
  },
  "daily_goal": {
    "target_min_trades_per_day": 1,
    "target_max_symbols_per_day": 2,
    "force_trade": false
  },
  "logging": {
    "decision_snapshot_dir": "decision_snapshots",
    "trade_record_dir": "trade_records",
    "daily_review_output": "daily_review_output.json"
  }
}
